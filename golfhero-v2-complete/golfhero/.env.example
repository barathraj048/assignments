# ============================================
# GOLFHERO - Environment Variables
# Copy this to .env.local and fill in values
# ============================================

# Supabase (create a new project at supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe (create account at stripe.com)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price IDs (create in Stripe dashboard)
STRIPE_MONTHLY_PRICE_ID=price_monthly_id_here
NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_ID=price_monthly_id_here
STRIPE_YEARLY_PRICE_ID=price_yearly_id_here
NEXT_PUBLIC_STRIPE_YEARLY_PRICE_ID=price_yearly_id_here

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Admin emails (comma-separated)
ADMIN_EMAILS=admin@yourdomain.com
